<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aurora Sky Library</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #818cf8;
            --secondary: #c084fc;
            --aurora-teal: rgba(45, 212, 191, 0.3);
            --aurora-purple: rgba(139, 92, 246, 0.3);
            --bg-space: #0f172a;
            --text-main: #f1f5f9;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
            background: var(--bg-space);
            min-height: 100vh;
            overflow-x: hidden;
        }

        #universe {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1; background: radial-gradient(ellipse at bottom, #1e293b 0%, #020617 100%);
            overflow: hidden;
        }

        .aurora-layer {
            position: absolute; width: 200%; height: 100%;
            top: -10%; left: -50%;
            background: repeating-linear-gradient(
                90deg,
                transparent 0%,
                var(--aurora-teal) 15%,
                transparent 30%,
                var(--aurora-purple) 45%,
                transparent 60%
            );
            filter: blur(100px);
            opacity: 0.5;
            animation: auroraFlow 20s infinite linear;
        }

        @keyframes auroraFlow {
            from { transform: translateX(-20%) skewX(-10deg); }
            to { transform: translateX(0%) skewX(10deg); }
        }

        #landingPage {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; justify-content: center; align-items: center;
            z-index: 2000; background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(15px); transition: 1.2s cubic-bezier(0.7, 0, 0.3, 1);
        }

        #landingPage.hidden { transform: translateY(-100%); opacity: 0; }

        .welcome-card {
            display: flex; align-items: center; gap: 40px;
            max-width: 900px; padding: 40px;
        }

        .profile-frame {
            position: relative;
            animation: floatProfile 6s infinite ease-in-out;
            flex-shrink: 0;
        }

        @keyframes floatProfile {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(1.5deg); }
        }

        .profile-frame img {
            width: 260px;
            height: 360px;
            object-fit: cover;
            border-radius: 40px 15px; 
            border: 2px solid var(--primary);
            box-shadow: 0 0 40px rgba(129, 140, 248, 0.3);
        }

        .welcome-info h1 {
            font-family: 'Playfair Display', serif; font-size: 3.5rem;
            line-height: 1.1; margin-bottom: 20px;
            background: linear-gradient(to bottom right, #fff, var(--secondary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 80px 20px; display: none; }
        .container.active { display: block; }

        .glass-btn {
            background: linear-gradient(45deg, var(--primary), var(--secondary));
            color: white; border: none; padding: 14px 28px; border-radius: 12px;
            cursor: pointer; font-weight: 700; transition: 0.4s;
            box-shadow: 0 10px 20px rgba(129, 140, 248, 0.25);
        }

        .book-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 30px; margin-top: 40px;
        }

        .book-card {
            background: rgba(255, 255, 255, 0.03); border-radius: 24px; padding: 20px;
            border: 1px solid rgba(255,255,255,0.08); transition: 0.5s;
            backdrop-filter: blur(10px); text-align: center;
        }

        .auto-cover {
            width: 100%; height: 280px; border-radius: 16px;
            display: flex; flex-direction: column; justify-content: center;
            padding: 20px; margin-bottom: 15px; color: white;
            position: relative; overflow: hidden;
            background-size: cover !important;
            background-position: center !important;
        }

        .cover-content { position: relative; z-index: 2; }
        .cover-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; margin-bottom: 10px; }

        .modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(2, 6, 23, 0.95); display: none;
            justify-content: center; align-items: center; z-index: 3000;
        }
        .modal-content {
            background: #1e293b; padding: 40px; border-radius: 28px;
            width: 90%; max-width: 420px; border: 1px solid var(--primary);
        }
        input, select {
            width: 100%; padding: 14px; margin: 10px 0;
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px; color: white;
        }
    </style>
</head>
<body>

    <div id="universe">
        <div class="aurora-layer"></div>
    </div>

    <!-- LANDING PAGE -->
    <div id="landingPage">
        <div class="welcome-card">
            <div class="profile-frame">
                <!-- MEMPERBAIKI PATH GAMBAR -->
                <img src="dest pic.jpeg" alt="Librarian">
            </div>
            <div class="welcome-info">
                <p style="color: var(--primary); font-weight: 800; letter-spacing: 4px; margin-bottom: 8px; font-size: 0.8rem;">VIRTUAL ARCHIVE 2026</p>
                <h1>Aurora Sky Library</h1>
                <p style="margin-bottom: 35px; opacity: 0.7; font-size: 1.1rem; line-height: 1.5;">Kelola koleksi buku Anda dengan atmosfer langit malam yang tak terbatas.</p>
                <button class="glass-btn" onclick="masuk()">Buka Katalog</button>
            </div>
        </div>
    </div>

    <!-- MAIN APP -->
    <div class="container" id="mainApp">
        <header style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 50px;">
            <div>
                <h2 style="font-family: 'Playfair Display'; font-size: 2.5rem;">Katalog Utama</h2>
                <p style="opacity: 0.5;">Arsip digital di bawah cahaya Aurora</p>
            </div>
            <button class="glass-btn" onclick="bukaModal()">+ Tambah Koleksi</button>
        </header>
        <div class="book-grid" id="bookGrid"></div>
    </div>

    <!-- MODAL (Formulir Tambah Buku) -->
    <div class="modal" id="bookModal">
        <div class="modal-content">
            <h2 id="modalTitle" style="font-family: 'Playfair Display'; margin-bottom: 15px;">Entri Koleksi</h2>
            <input type="text" id="inJudul" placeholder="Judul Buku">
            <input type="text" id="inPenulis" placeholder="Nama Penulis">
            <input type="text" id="inKategori" placeholder="Kategori">
            <input type="file" id="inFile" accept="image/*">
            <select id="inWarna">
                <option value="linear-gradient(135deg, #1e3a8a, #581c87)">Midnight Nebula</option>
                <option value="linear-gradient(135deg, #064e3b, #115e59)">Deep Aurora</option>
            </select>
            <div style="display: flex; gap: 10px; margin-top: 20px;">
                <button class="glass-btn" style="flex: 2;" onclick="simpanBuku()">Simpan</button>
                <button class="glass-btn" style="flex: 1; background: #334155;" onclick="tutupModal()">Batal</button>
            </div>
        </div>
    </div>

    <script>
        // MENAMBAHKAN DATA BUKU CONTOH AGAR TIDAK KOSONG
        const defaultBooks = [
            { id: '1', judul: 'Laskar Pelangi', penulis: 'Andrea Hirata', kategori: 'Novel', warna: 'linear-gradient(135deg, #1e3a8a, #581c87)', cover: null },
            { id: '2', judul: 'Bumi', penulis: 'Tere Liye', kategori: 'Fiksi', warna: 'linear-gradient(135deg, #064e3b, #115e59)', cover: null }
        ];

        let libraryData = JSON.parse(localStorage.getItem('aurora_library_db')) || defaultBooks;
        let targetEditId = null;

        function masuk() {
            document.getElementById('landingPage').classList.add('hidden');
            setTimeout(() => { 
                document.getElementById('mainApp').classList.add('active');
                renderLibrary();
            }, 600);
        }

        function bukaModal() { 
            targetEditId = null;
            document.getElementById('bookModal').style.display = 'flex'; 
        }

        function tutupModal() { document.getElementById('bookModal').style.display = 'none'; }

        function renderLibrary() {
            const grid = document.getElementById('bookGrid');
            grid.innerHTML = '';
            libraryData.forEach((buku) => {
                const bgStyle = buku.cover ? `url(${buku.cover})` : buku.warna;
                const div = document.createElement('div');
                div.className = 'book-card';
                div.innerHTML = `
                    <div class="auto-cover" style="background: ${bgStyle};">
                        <div class="cover-content">
                            <div class="cover-title">${buku.judul}</div>
                            <div style="font-size: 0.7rem;">${buku.penulis}</div>
                        </div>
                    </div>
                    <h3>${buku.judul}</h3>
                    <p style="font-size: 0.8rem; opacity: 0.5;">${buku.kategori}</p>
                `;
                grid.appendChild(div);
            });
        }

        function simpanBuku() {
            const judul = document.getElementById('inJudul').value;
            const penulis = document.getElementById('inPenulis').value;
            const kategori = document.getElementById('inKategori').value;
            const warna = document.getElementById('inWarna').value;
            
            if (!judul || !penulis) { alert("Judul dan Penulis wajib diisi!"); return; }

            const bukuBaru = { id: Date.now().toString(), judul, penulis, kategori, warna, cover: null };
            libraryData.push(bukuBaru);
            localStorage.setItem('aurora_library_db', JSON.stringify(libraryData));
            renderLibrary();
            tutupModal();
        }
    </script>
</body>
</html>